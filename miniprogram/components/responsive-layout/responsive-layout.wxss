/* 响应式布局组件样式 */

/* 基础容器样式 */
.responsive-layout {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

/* 桌面端布局 */
.desktop-layout {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 移动端布局 */
.mobile-layout {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

/* 网格容器 */
.grid-container {
  width: 100%;
  display: grid;
  gap: 16rpx;
  box-sizing: border-box;
}

/* 响应式网格布局 */
/* 桌面端：4列网格 */
@media (min-width: 768px) {
  .grid-container {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* 平板端：3列网格 */
@media (min-width: 480px) and (max-width: 767px) {
  .grid-container {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* 移动端：2列网格 */
@media (max-width: 479px) {
  .grid-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* 响应式卡片样式 */
.responsive-card {
  background-color: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 20rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

/* 桌面端卡片悬停效果 */
@media (min-width: 768px) {
  .responsive-card:hover {
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
    transform: translateY(-2rpx);
  }
}

/* 响应式按钮样式 */
.responsive-button {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s ease;
  cursor: pointer;
}

/* 桌面端按钮悬停效果 */
@media (min-width: 768px) {
  .responsive-button:hover {
    opacity: 0.9;
    transform: translateY(-1rpx);
  }
}

/* 响应式表单元素 */
.responsive-input {
  width: 100%;
  padding: 16rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

/* 桌面端输入框聚焦效果 */
@media (min-width: 768px) {
  .responsive-input:focus {
    border-color: #1890ff;
    box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.1);
  }
}

/* 响应式文本 */
.responsive-text {
  font-size: 28rpx;
  line-height: 1.5;
}

/* 桌面端文本大小 */
@media (min-width: 768px) {
  .responsive-text {
    font-size: 32rpx;
    line-height: 1.6;
  }
}

/* 响应式标题 */
.responsive-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 桌面端标题大小 */
@media (min-width: 768px) {
  .responsive-title {
    font-size: 44rpx;
    margin-bottom: 28rpx;
  }
}

/* 响应式间距 */
.responsive-margin {
  margin: 15rpx;
}

@media (min-width: 768px) {
  .responsive-margin {
    margin: 25rpx;
  }
}

.responsive-padding {
  padding: 15rpx;
}

@media (min-width: 768px) {
  .responsive-padding {
    padding: 25rpx;
  }
}
