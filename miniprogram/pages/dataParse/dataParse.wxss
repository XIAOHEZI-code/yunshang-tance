/* dataParse.wxss - 文件上传与解析页面样式 */

/* 页面容器 */
.container {
  padding: var(--space-4);
  background-color: var(--bg-default);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 页面头部 */
.header {
  text-align: center;
  margin-bottom: var(--space-4);
  padding: var(--space-4) 0;
  background-color: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.title {
  display: block;
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.subtitle {
  display: block;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

/* 文件上传区域 */
.upload-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-4);
}

/* 上传按钮 */
.upload-btn {
  width: 100%;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: var(--bg-elevated);
  border: 2rpx dashed var(--brand-primary);
  border-radius: var(--radius-xl);
  cursor: pointer;
  transition: all var(--transition-fast);
}

.upload-btn:hover {
  border-color: var(--brand-primary-hover);
  background-color: var(--bg-hover);
}

.upload-icon {
  font-size: var(--text-5xl);
  margin-bottom: var(--space-2);
  color: var(--brand-primary);
}

.upload-text {
  font-size: var(--text-base);
  color: var(--brand-primary);
  margin-bottom: var(--space-2);
  font-weight: var(--font-semibold);
}

.upload-hint {
  font-size: var(--text-xs);
  color: var(--text-muted);
  text-align: center;
  padding: 0 var(--space-3);
}

/* 解析按钮 */
.parse-btn {
  width: 100%;
  font-size: var(--text-base);
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-xl);
  background-color: var(--brand-primary);
  color: var(--text-on-brand);
  transition: background-color var(--transition-fast);
}

.parse-btn:active {
  background-color: var(--brand-primary-active);
}

/* 状态提示区域 */
.status-section {
  margin-bottom: var(--space-4);
  padding: var(--space-4);
  border-radius: var(--radius-xl);
  background-color: var(--bg-elevated);
  box-shadow: var(--shadow-sm);
}

.status-text {
  font-size: var(--text-sm);
  display: block;
  text-align: center;
}

.status-text.success {
  color: var(--status-success);
}

.status-text.error {
  color: var(--status-error);
}

.status-text.info {
  color: var(--status-info);
}

/* 数据预览区域 */
.preview-section {
  background-color: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: var(--shadow-sm);
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--divider);
}

.preview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.preview-info {
  font-size: 24rpx;
  color: #999;
}

/* 数据表格容器 */
.data-table-container {
  width: 100%;
  height: 400rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  background-color: #fff;
}

/* 数据表格 */
.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 24rpx;
}

/* 表头 */
.table-header {
  background-color: #fafafa;
}

.table-th {
  padding: 15rpx 10rpx;
  text-align: left;
  font-weight: bold;
  color: #333;
  border-bottom: 2rpx solid #f0f0f0;
  white-space: nowrap;
  min-width: 120rpx;
}

/* 数据行 */
.table-row {
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s ease;
}

.table-row:hover {
  background-color: #f5f7fa;
}

/* 数据单元格 */
.table-td {
  padding: 15rpx 10rpx;
  color: #666;
  white-space: nowrap;
  min-width: 120rpx;
}

/* 更多数据提示 */
.preview-more {
  text-align: center;
  padding: 15rpx;
  background-color: #fafafa;
  border-radius: 0 0 8rpx 8rpx;
  margin-top: -20rpx;
}

.preview-more text {
  font-size: 22rpx;
  color: #999;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 10rpx;
  margin-top: 20rpx;
}

/* 加载动画 */
.loading {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 10rpx;
  }
  
  .upload-btn {
    height: 160rpx;
  }
  
  .upload-icon {
    font-size: 48rpx;
  }
  
  .data-table-container {
    height: 300rpx;
  }
}

/* ========== PNG 图标样式 ========== */
.page-title-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: var(--text-2xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
}

.page-title-icon {
  width: 48rpx;
  height: 48rpx;
}

.upload-area-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.7;
}