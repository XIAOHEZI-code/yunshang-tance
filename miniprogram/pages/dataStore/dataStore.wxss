/* dataStore.wxss - 数据管理页面样式（美化版，适配安卓手机） */

/* ========== 基础变量 ========== */
:root {
  --primary-color: #1565C0;
  --primary-light: #E3F2FD;
  --success-color: #43A047;
  --success-light: #E8F5E9;
  --danger-color: #E53935;
  --danger-light: #FFEBEE;
  --warning-color: #F57C00;
  --purple-color: #7B1FA2;
  --purple-light: #F3E5F5;
  
  --bg-primary: #F5F6FA;
  --bg-secondary: #FFFFFF;
  --bg-tertiary: #F0F2F5;
  --bg-card: #FFFFFF;
  
  --text-primary: #1A1A2E;
  --text-secondary: rgba(26, 26, 46, 0.75);
  --text-tertiary: rgba(26, 26, 46, 0.55);
  --text-muted: rgba(26, 26, 46, 0.35);
  
  --border-color: rgba(0, 0, 0, 0.08);
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
}

/* ========== 页面容器 ========== */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F6FA 0%, #ECEEF3 100%);
  padding: 24rpx;
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

/* ========== 页面头部 ========== */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.header-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  animation: pulse 2s ease-in-out infinite;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  text-align: center;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
}

/* ========== 空状态卡片 ========== */
.empty-state-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 80rpx 48rpx;
  margin: 24rpx 0;
  border: 1rpx solid var(--border-color);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, rgba(21, 101, 192, 0.06) 0%, rgba(21, 101, 192, 0.03) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border: 2rpx solid rgba(21, 101, 192, 0.12);
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 48rpx;
  text-align: center;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1565C0 0%, #0D47A1 100%);
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(21, 101, 192, 0.20);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(21, 101, 192, 0.15);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ========== 卡片通用样式 ========== */
.overview-card,
.preview-card,
.columns-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ========== 刷新按钮 ========== */
.update-badge {
  display: flex;
  align-items: center;
  background: rgba(21, 101, 192, 0.06);
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(21, 101, 192, 0.15);
}

.update-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.update-text {
  font-size: 24rpx;
  color: var(--primary-color);
}

/* ========== 统计网格 ========== */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  min-width: 280rpx;
  display: flex;
  align-items: center;
  background: var(--bg-tertiary);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stat-item.full-width {
  flex: 100%;
  min-width: 100%;
}

.stat-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.stat-icon-wrapper.blue {
  background: rgba(21, 101, 192, 0.08);
}

.stat-icon-wrapper.green {
  background: rgba(67, 160, 71, 0.08);
}

.stat-icon-wrapper.purple {
  background: rgba(123, 31, 162, 0.08);
}

.stat-icon {
  font-size: 40rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.stat-value-small {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  line-height: 1.4;
  word-break: break-all;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* ========== 操作区域 ========== */
.action-section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.action-grid {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  border-radius: var(--radius-lg);
  border: none;
  background: transparent;
  transition: all 0.3s ease;
}

.action-btn::after {
  border: none;
}

.action-btn.danger {
  background: linear-gradient(135deg, rgba(229, 57, 53, 0.06) 0%, rgba(229, 57, 53, 0.03) 100%);
  border: 1rpx solid rgba(229, 57, 53, 0.15);
}

.action-btn.danger:active {
  background: rgba(229, 57, 53, 0.10);
  transform: scale(0.98);
}

.action-btn.primary {
  background: linear-gradient(135deg, rgba(21, 101, 192, 0.06) 0%, rgba(21, 101, 192, 0.03) 100%);
  border: 1rpx solid rgba(21, 101, 192, 0.15);
}

.action-btn.primary:active {
  background: rgba(21, 101, 192, 0.10);
  transform: scale(0.98);
}

.action-btn-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-btn.danger .action-btn-icon-wrapper {
  background: rgba(229, 57, 53, 0.08);
}

.action-btn.primary .action-btn-icon-wrapper {
  background: rgba(21, 101, 192, 0.08);
}

.action-btn-icon {
  font-size: 40rpx;
}

.action-btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.danger .action-btn-text {
  color: #E53935;
}

.action-btn.primary .action-btn-text {
  color: #1565C0;
}

/* ========== 数据预览卡片 ========== */
.preview-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: rgba(0, 0, 0, 0.03);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.table-scroll-view {
  width: 100%;
  background: var(--bg-tertiary);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.data-table-wrapper {
  min-width: 100%;
  display: inline-block;
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, rgba(21, 101, 192, 0.08) 0%, rgba(21, 101, 192, 0.04) 100%);
  padding: 0;
  white-space: nowrap;
  border-bottom: 1rpx solid var(--border-color);
}

.th-cell {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  padding: 20rpx 16rpx;
  border-right: 1rpx solid rgba(0, 0, 0, 0.04);
}

.th-cell:last-child {
  border-right: none;
}

.th-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200rpx;
}

.th-type {
  font-size: 20rpx;
  color: var(--text-tertiary);
  background: rgba(0, 0, 0, 0.04);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.table-body {
  max-height: 400rpx;
}

.table-row {
  display: flex;
  white-space: nowrap;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: background-color 0.2s ease;
}

.table-row.even {
  background: rgba(0, 0, 0, 0.01);
}

.table-row.odd {
  background: transparent;
}

.td-cell {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  padding: 20rpx 16rpx;
  border-right: 1rpx solid rgba(0, 0, 0, 0.03);
}

.td-cell:last-child {
  border-right: none;
}

.td-value {
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 180rpx;
  text-align: center;
}

.table-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-top: 16rpx;
  background: rgba(21, 101, 192, 0.03);
  border-radius: var(--radius-md);
  border: 1rpx dashed rgba(21, 101, 192, 0.12);
}

.hint-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ========== 列信息卡片 ========== */
.columns-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: rgba(0, 0, 0, 0.03);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.columns-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.column-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-secondary);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.column-item:active {
  background: rgba(0, 0, 0, 0.02);
}

.column-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.column-index {
  width: 44rpx;
  height: 44rpx;
  background: rgba(24, 144, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.column-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.column-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-right: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 280rpx;
}

.primary-tag {
  font-size: 18rpx;
  color: #ff7875;
  background: rgba(229, 57, 53, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.column-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.column-type-badge.string {
  background: rgba(67, 160, 71, 0.06);
}

.column-type-badge.number {
  background: rgba(245, 124, 0, 0.06);
}

.column-type-badge.boolean {
  background: rgba(123, 31, 162, 0.06);
}

.column-type-badge.date {
  background: rgba(21, 101, 192, 0.06);
}

.type-text {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

/* ========== 底部安全区域 ========== */
.safe-area-bottom {
  height: 48rpx;
}

/* ========== 动画 ========== */
@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

/* ========== 响应式适配 - 安卓手机（360rpx-414rpx宽度） ========== */
@media (max-width: 414rpx) {
  .page-container {
    padding: 16rpx;
  }
  
  .header-section {
    padding: 32rpx 16rpx 24rpx;
  }
  
  .header-icon {
    font-size: 56rpx;
  }
  
  .page-title {
    font-size: 34rpx;
  }
  
  .page-subtitle {
    font-size: 24rpx;
  }
  
  .overview-card,
  .preview-card,
  .columns-card {
    padding: 20rpx;
  }
  
  .stat-item {
    padding: 20rpx;
    min-width: 100%;
  }
  
  .stat-icon-wrapper {
    width: 64rpx;
    height: 64rpx;
  }
  
  .stat-icon {
    font-size: 32rpx;
  }
  
  .stat-value {
    font-size: 32rpx;
  }
  
  .action-grid {
    gap: 12rpx;
  }
  
  .action-btn {
    padding: 24rpx 16rpx;
  }
  
  .action-btn-icon-wrapper {
    width: 64rpx;
    height: 64rpx;
  }
  
  .action-btn-icon {
    font-size: 32rpx;
  }
  
  .action-btn-text {
    font-size: 24rpx;
  }
  
  .th-cell,
  .td-cell {
    min-width: 140rpx;
    padding: 16rpx 12rpx;
  }
  
  .th-name,
  .column-name {
    max-width: 160rpx;
  }
}

@media (min-width: 415rpx) and (max-width: 750rpx) {
  .stat-item {
    flex: 1;
    min-width: 45%;
  }
}

/* ========== PNG 图标样式 ========== */
.header-icon-img {
  width: 64rpx;
  height: 64rpx;
}

.empty-icon-img {
  width: 100rpx;
  height: 100rpx;
  opacity: 0.6;
}

.action-icon-img {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.9;
}
