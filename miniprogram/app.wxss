/* app.wxss - 全局样式 v2.0 */
@import './styles/variables.wxss';

/* ========== 页面基础 ========== */
page {
  background-color: var(--bg-base);
  color: var(--text-primary);
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ========== 页面容器 ========== */
.page-container {
  min-height: 100vh;
  background: var(--bg-base);
  padding: var(--space-4);
  padding-bottom: var(--space-8);
  box-sizing: border-box;
  max-width: 100%;
  margin: 0 auto;
}

/* ========== 桌面端布局优化 ========== */
@media (min-width: 768px) {
  .page-container {
    max-width: 1400px;
    padding: var(--space-6);
    padding-bottom: var(--space-10);
  }
  
  /* 更宽的卡片网格 */
  .card-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }
  
  /* 数据概览区域 */
  .grid.grid-cols-2 {
    grid-template-columns: repeat(4, 1fr);
  }
  
  /* 快速操作按钮 */
  .button-group.button-group-vertical {
    flex-direction: row;
    justify-content: center;
  }
  
  .button-group.button-group-vertical .btn {
    flex: 1;
    max-width: 300px;
  }
}

/* ========== 大屏幕桌面端优化 ========== */
@media (min-width: 1200px) {
  .page-container {
    max-width: 1600px;
  }
  
  /* 更大的卡片 */
  .card {
    min-height: 320rpx;
    padding: var(--space-6);
  }
  
  /* 更大的字体 */
  .page-title {
    font-size: var(--text-4xl);
  }
  
  .page-subtitle {
    font-size: var(--text-2xl);
  }
  
  /* 更大的图标 */
  .icon-container {
    padding: var(--space-4);
  }
  
  .icon-container text {
    font-size: var(--text-5xl);
  }
}

/* ========== 玻璃拟态卡片 ========== */
.glass-card {
  background: var(--bg-card-primary);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid var(--border-default);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  transition: all var(--transition-normal);
}

.glass-card-hover:active {
  transform: scale(0.98);
  background: var(--bg-glass-hover);
  box-shadow: var(--shadow-sm);
}

/* ========== 霓虹发光卡片 ========== */
.glow-card {
  background: var(--gradient-card);
  border: 1rpx solid var(--border-brand);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md), var(--glow-brand);
  position: relative;
  overflow: hidden;
}

.glow-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--brand-primary), transparent);
}

/* ========== 按钮系统 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3) var(--space-5);
  border-radius: var(--radius-lg);
  font-size: var(--text-base);
  font-weight: var(--font-medium);
  transition: all var(--transition-fast);
  border: none;
  position: relative;
  overflow: hidden;
}

.btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.1) 0%, transparent 100%);
  pointer-events: none;
}

.btn-primary {
  background: var(--gradient-brand);
  color: #FFFFFF;
  box-shadow: var(--glow-brand);
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(232, 93, 4, 0.3);
}

.btn-secondary {
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 1rpx solid var(--border-default);
}

.btn-secondary:active {
  background: var(--bg-glass-hover);
}

.btn-success {
  background: var(--gradient-success);
  color: white;
  box-shadow: var(--glow-success);
}

.btn-error {
  background: var(--gradient-error);
  color: white;
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-subtle);
}

.btn-ghost:hover {
  background: var(--bg-glass);
  color: var(--text-primary);
}

.btn-lg {
  padding: var(--space-4) var(--space-6);
  font-size: var(--text-lg);
  border-radius: var(--radius-xl);
}

.btn-sm {
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  border-radius: var(--radius-md);
}

/* ========== 输入框 ========== */
.input {
  width: 100%;
  padding: var(--space-3) var(--space-4);
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-default);
  border-radius: var(--radius-lg);
  color: var(--text-primary);
  font-size: var(--text-base);
  transition: all var(--transition-fast);
  box-sizing: border-box;
}

.input:focus {
  outline: none;
  border-color: var(--brand-primary);
  box-shadow: 0 0 0 3rpx rgba(232, 93, 4, 0.1);
}

.input::placeholder {
  color: var(--text-muted);
}

/* ========== 标签与徽章 ========== */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
}

.badge-primary {
  background: rgba(232, 93, 4, 0.10);
  color: var(--text-brand);
  border: 1rpx solid rgba(232, 93, 4, 0.20);
}

.badge-success {
  background: rgba(67, 160, 71, 0.10);
  color: var(--text-success);
}

.badge-warning {
  background: rgba(245, 124, 0, 0.10);
  color: var(--text-warning);
}

.badge-error {
  background: rgba(229, 57, 53, 0.10);
  color: var(--text-error);
}

/* ========== 文字工具类 ========== */
.text-gradient {
  background: var(--gradient-brand);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-glow {
  text-shadow: 0 0 20rpx rgba(232, 93, 4, 0.25);
}

/* ========== 布局工具类 ========== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

.grid { display: grid; }
.grid-cols-2 { grid-template-columns: repeat(2, 1fr); }
.grid-cols-3 { grid-template-columns: repeat(3, 1fr); }
.grid-cols-4 { grid-template-columns: repeat(4, 1fr); }

.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }
.gap-4 { gap: var(--space-4); }
.gap-5 { gap: var(--space-5); }

/* ========== 间距工具类 ========== */
.m-0 { margin: 0; }
.m-2 { margin: var(--space-2); }
.m-3 { margin: var(--space-3); }
.m-4 { margin: var(--space-4); }

.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mt-5 { margin-top: var(--space-5); }

.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }
.mb-5 { margin-bottom: var(--space-5); }
.mb-6 { margin-bottom: var(--space-6); }

.p-3 { padding: var(--space-3); }
.p-4 { padding: var(--space-4); }
.p-5 { padding: var(--space-5); }

/* ========== 动画工具类 ========== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 4rpx 16rpx rgba(232, 93, 4, 0.15); }
  50% { box-shadow: 0 4rpx 24rpx rgba(232, 93, 4, 0.25); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.animate-fade-in {
  animation: fadeIn 0.6s var(--ease-out) forwards;
}

.animate-fade-in-up {
  animation: fadeInUp 0.6s var(--ease-out) forwards;
}

.animate-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

.animate-float {
  animation: float 3s ease-in-out infinite;
}

/* 延迟动画 */
.delay-100 { animation-delay: 100ms; }
.delay-200 { animation-delay: 200ms; }
.delay-300 { animation-delay: 300ms; }
.delay-400 { animation-delay: 400ms; }

/* ========== 滚动条美化 ========== */
::-webkit-scrollbar {
  width: 6rpx;
  height: 6rpx;
}

::-webkit-scrollbar-track {
  background: var(--bg-elevated);
  border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb {
  background: var(--border-strong);
  border-radius: var(--radius-full);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--brand-primary);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-10) var(--space-6);
  text-align: center;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-2xl);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: var(--space-5);
  border: 1rpx solid var(--border-subtle);
}

.empty-state-title {
  font-size: var(--text-xl);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.empty-state-desc {
  font-size: var(--text-base);
  color: var(--text-tertiary);
  margin-bottom: var(--space-5);
  max-width: 80%;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background: var(--divider);
  margin: var(--space-4) 0;
}

/* ========== 加载状态 ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-8);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-default);
  border-top-color: var(--brand-primary);
  border-radius: var(--radius-full);
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--space-3);
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}

/* ========== 补充工具类 ========== */
/* 文本工具类 */
.text-center { text-align: center; }
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-5xl { font-size: var(--text-5xl); }
.text-4xl { font-size: var(--text-4xl); }
.text-xl { font-size: var(--text-xl); }
.text-lg { font-size: var(--text-lg); }
.text-sm { font-size: var(--text-sm); }
.text-small { font-size: var(--text-sm); }
.font-bold { font-weight: var(--font-bold); }
.font-medium { font-weight: var(--font-medium); }

/* 颜色工具类 */
.bg-primary-light { background-color: rgba(232, 93, 4, 0.06); }
.bg-secondary { background-color: var(--bg-surface); }
.bg-tertiary { background-color: var(--bg-card-primary); }
.bg-primary { background-color: var(--brand-primary); }
.bg-info { background-color: var(--info); }
.bg-success { background-color: var(--success); }
.bg-warning { background-color: var(--warning); }

/* 形状工具类 */
.rounded-full { border-radius: var(--radius-full); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-lg { border-radius: var(--radius-lg); }

/* 布局工具类 */
.w-full { width: 100%; }
.inline-block { display: inline-block; }

/* 间距工具类 */
.mr-2 { margin-right: var(--space-2); }

/* 动画工具类 */
.animate-slide-up { animation: slideUp 0.5s ease-out; }
.animate-slide-up-delay { animation: slideUp 0.5s ease-out 0.1s both; }
.animate-slide-up-delay-2 { animation: slideUp 0.5s ease-out 0.2s both; }
.animate-slide-up-delay-3 { animation: slideUp 0.5s ease-out 0.3s both; }
.animate-pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }

@keyframes slideUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 边框工具类 */
.border { border: 1rpx solid var(--border-default); }
.border-border-color-light { border-color: var(--border-subtle); }

/* 卡片悬停效果 */
.card-hover:active {
  transform: scale(0.98);
}

/* 按钮工具类 */
.btn-block { width: 100%; }
.btn-md {
  padding: var(--space-3) var(--space-5);
  font-size: var(--text-base);
  border-radius: var(--radius-lg);
}

/* 页面标题 */
.page-title {
  font-size: var(--text-3xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.page-subtitle {
  font-size: var(--text-xl);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.text-normal {
  font-weight: var(--font-normal);
}

/* 公告栏 */
.announcement-bar {
  background: linear-gradient(135deg, rgba(232, 93, 4, 0.06) 0%, rgba(244, 140, 6, 0.04) 100%);
  border: 1rpx solid rgba(232, 93, 4, 0.15);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
}

.announcement-icon {
  font-size: var(--text-xl);
  flex-shrink: 0;
}

.announcement-text {
  flex: 1;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: var(--space-3);
}

.button-group-vertical {
  flex-direction: column;
}
